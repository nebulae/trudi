# TRUDI MCP Server — environment configuration

# IOC Enrichment (optional — server degrades gracefully without these)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Foundation-Sec endpoint (local vLLM or HF Inference Endpoint)
# Local:  http://localhost:8000
# HF:     https://your-endpoint.huggingface.cloud
FOUNDATION_SEC_URL=http://localhost:8000

# Volatility 3 symbol cache — must be writable by the current user
# Default: ~/.cache/volatility3/symbols (auto-created)
# Override to a case-specific path if needed
VOLATILITY_SYMBOLS=
