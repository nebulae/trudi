# TRUDI MCP Server — environment configuration

# IOC Enrichment (optional — server degrades gracefully without these)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ── Reasoning backend ──────────────────────────────────────────────────────
# REASON_BACKEND selects which model powers the adversarial review loop.
# Auto-detected from available keys if not set explicitly.

# Default: Claude API (best quality, no server required).
# Find Evil! submission config — Opus on BOTH reasoning surfaces (reason.* + dair.*).
# Add your key below and you're ready for a full-quality run from a fresh install.
REASON_BACKEND=claude
ANTHROPIC_API_KEY=                       # required — paste your sk-ant-... key here
REASON_MODEL=claude-opus-4-7             # submission default; claude-opus-4-8 is newer
# REASON_MODEL=claude-haiku-4-5-20251001 # faster/cheaper alternative for quick runs

# Alternative: any OpenAI-compatible endpoint
# (OpenAI, Foundation-Sec vLLM, Ollama, local LLM, HF endpoint)
# REASON_BACKEND=openai-compat
# REASON_URL=https://api.openai.com/v1        # or http://localhost:8000 for local vLLM
# REASON_API_KEY=sk-...                        # OpenAI key, HF token, or leave blank for local
# REASON_MODEL=gpt-4o-mini                     # or fdtn-ai/Foundation-Sec-8B-Reasoning

# Deprecated aliases (still work — kept for backward compatibility)
# FOUNDATION_SEC_URL=http://localhost:8000     # maps to REASON_URL
# HF_TOKEN=                                    # maps to REASON_API_KEY

# ── DAIR Director Agent ───────────────────────────────────────────────────────
# Separate config from reason.* — can point to a different model or endpoint.
# Auto-detected from available keys if DAIR_BACKEND is not set explicitly.

DAIR_BACKEND=claude                     # "claude" or "openai-compat"
DAIR_MODEL=claude-opus-4-7              # submission default; matches REASON_MODEL above
# DAIR_MODEL=claude-haiku-4-5-20251001  # faster/cheaper alternative

# Alternative: separate OpenAI-compatible endpoint (e.g. second vLLM instance)
# DAIR_BACKEND=openai-compat
# DAIR_URL=http://localhost:8001         # separate from REASON_URL, or the same
# DAIR_API_KEY=hf_...
# DAIR_MODEL=fdtn-ai/Foundation-Sec-8B-Reasoning

# ── Tool execution timeouts (seconds) ────────────────────────────────────────
# Values below are tuned for an Opus reason+DAIR run (the submission config) on
# WSL2. Opus reasoning/DAIR calls routinely take 2-3 min, so the stock 120/300s
# floors time out — these raised defaults avoid that. Lower them for haiku.

TRUDI_DEFAULT_TIMEOUT=600     # most tools (regripper, yara, strings, etc.)
TRUDI_VOL_TIMEOUT=1800        # vol plugins, hashing dirs, heavy sleuthkit ops
TRUDI_PLASO_TIMEOUT=21600     # full disk timeline (6 hours)
TRUDI_REASON_TIMEOUT=600      # reasoning backend HTTP call (raised for Opus)
TRUDI_DAIR_TIMEOUT=600        # DAIR director (Opus can take 2-3 min)

# Volatility 3 symbol cache — must be writable by the current user
# Default: ~/.cache/volatility3/symbols (auto-created)
VOLATILITY_SYMBOLS=
