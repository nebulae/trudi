      import csv,glob
      f=glob.glob('evtx_security/security_accounts_logons.csv')[0]
      rows=list(csv.DictReader(open(f,encoding='utf-8',errors='replace')))
      # find 4624 logons matching the subject logon ids of interest, and all interactive/RDP logons
      print("=== 4624 logons with TargetLogonId 0x668B4 or 0x4C731 (the creator sessions) ===")
      for r in rows:
          if r['EventId']=='4624':
              pd=(r.get('PayloadData1','') or '')+ (r.get('PayloadData2','') or '')+(r.get('PayloadData3','') or '')+(r.get('PayloadData4','') or
      '')+(r.get('PayloadData5','') or '')+(r.get('MapDescription','') or '')
              if '668B4' in pd or '4C731' in pd:
                  print(r['TimeCreated'], 'type=',r.get('PayloadData1',''), '|',
      r.get('PayloadData2',''),'|',r.get('PayloadData3',''),'|RemoteHost=',r.get('RemoteHost',''))
      print()
      print("=== All 4624 logon TYPES summary + any type 3/10 (network/RDP) ===")
      from collections import Counter
      types=Counter()
      rdp=[]
      for r in rows:
          if r['EventId']=='4624':
              lt=r.get('PayloadData1','')
              types[lt]+=1
              # capture remote/network
              rh=r.get('RemoteHost','') or ''
              if ('%%10' in lt) or ('Type 10' in lt) or ('Type 3' in lt) or ('RemoteInteractive' in lt) or ('Network' in lt and 'NetworkClear' not in lt):
                  if rh and rh not in ('-','::1','127.0.0.1','') :
                      rdp.append((r['TimeCreated'],lt,rh,r.get('UserName','')))
      for k,v in types.most_common():
          print(v, '|', k)
      print()
      print("=== logons with a real remote host/IP ===")
      seen=set()
      for r in rows:
          if r['EventId'] in ('4624','4625'):
              rh=r.get('RemoteHost','') or ''
              if rh and rh not in ('-','::1','127.0.0.1','localhost',''):
                  key=(rh,r.get('PayloadData1',''))
                  if key not in seen:
                      seen.add(key)
                      print(r['TimeCreated'],r['EventId'],'type=',r.get('PayloadData1',''),'remote=',rh,'user=',r.get('UserName',''))
      PY)
